                                <a href="#" class="btn-play-hero" style="background: #ff3c00; font-size: 1.1rem; padding: 10px 24px;"><i class="fas fa-play me-2"></i>Xem ngay</a>
                                <a href="#" class="btn-icon-circle" style="background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.2);"><i class="fas fa-heart"></i></a>
                                <a href="#" class="btn-icon-circle" style="background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.2);"><i class="fas fa-share-alt"></i></a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Thể loại (Image 1 bottom) -->
                <h4 class="section-title mt-4">Thể loại</h4>
                <div class="section-carousel mb-4 pb-2">
                    <a href="#" class="genre-card" style="border-radius: 8px; height: 120px; background: #000; width: 220px; flex-shrink: 0;">
                        <img src="/images/posters/hanh-dong.jpg" alt="Hành động" onerror="this.src='/images/default-poster.jpg'" style="opacity: 0.6;">
                        <div class="genre-title" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.8);">Hành động</div>
                    </a>
                    <a href="#" class="genre-card" style="border-radius: 8px; height: 120px; background: #000; width: 220px; flex-shrink: 0;">
                        <img src="/images/posters/tam-ly.jpg" alt="Tâm lý" onerror="this.src='/images/default-poster.jpg'" style="opacity: 0.6;">
                        <div class="genre-title" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.8);">Tâm lý</div>
                    </a>
                    <a href="#" class="genre-card" style="border-radius: 8px; height: 120px; background: #000; width: 220px; flex-shrink: 0;">
                        <img src="/images/posters/kinh-di.jpg" alt="Kinh dị" onerror="this.src='/images/default-poster.jpg'" style="opacity: 0.6;">
                        <div class="genre-title" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.8);">Kinh dị</div>
                    </a>
                    <a href="#" class="genre-card" style="border-radius: 8px; height: 120px; background: #000; width: 220px; flex-shrink: 0;">
                        <img src="/images/posters/hai-huoc.jpg" alt="Hài hước" onerror="this.src='/images/default-poster.jpg'" style="opacity: 0.6;">
                        <div class="genre-title" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.8);">Hài hước</div>
                    </a>
                    <a href="#" class="genre-card" style="border-radius: 8px; height: 120px; background: #000; width: 220px; flex-shrink: 0;">
                        <img src="/images/posters/tinh-cam.jpg" alt="Tình cảm" onerror="this.src='/images/default-poster.jpg'" style="opacity: 0.6;">
                        <div class="genre-title" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.8);">Tình cảm</div>
                    </a>
                    <a href="#" class="genre-card" style="border-radius: 8px; height: 120px; background: #000; width: 220px; flex-shrink: 0;">
                        <img src="/images/posters/hoat-hinh.jpg" alt="Hoạt hình" onerror="this.src='/images/default-poster.jpg'" style="opacity: 0.6;">
                        <div class="genre-title" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.8);">Hoạt hình</div>
                    </a>
                </div>

                <!-- Tuyển tập của những tuyển tập (Image 2) -->
                <div class="d-flex align-items-center mb-1 mt-4">
                    <h4 class="section-title m-0">Tuyển tập của những tuyển tập</h4>
                </div>
                <div class="section-carousel pb-4">
                    @{
                        var tuyenTap = ViewBag.TuyenTap as List<FPTPlay.Models.Movie> ?? new List<FPTPlay.Models.Movie>();
                        foreach(var m in tuyenTap) {
                            <div class="ls-wrapper" style="width: 250px;">
                                <a href="/Movies/Details/@m.Id" class="ls-card" style="aspect-ratio: 16/9; width: 250px; border-radius: 8px; overflow: hidden; position: relative; display: block;">
                                    <img src="@m.PosterUrl" alt="@m.Title" onerror="this.src='/images/default-poster.jpg'" style="width: 100%; height: 100%; object-fit: cover;">
                                    @if (!string.IsNullOrEmpty(m.Description))
                                    {
                                        <span style="background: rgba(0,0,0,0.7); color: white; padding: 2px 6px; border-radius: 4px; font-size: 0.75rem; position: absolute; bottom: 8px; right: 8px;"><i class="fas fa-play-circle me-1"></i>@m.Description</span>
                                    }
                                </a>
                                <a href="/Movies/Details/@m.Id" class="ls-title fw-bold mt-2 text-white" style="font-size: 0.85rem;">@m.Title</a>
                            </div>
                        }
                    }
                </div>

                <!-- Phim lẻ có Thuyết minh - Lồng tiếng (Image 2) -->
                <div class="d-flex align-items-center mb-1 mt-4">
                    <h4 class="section-title m-0">Phim lẻ có Thuyết minh - Lồng tiếng <i class="fas fa-chevron-right ms-2 fs-6 text-muted"></i></h4>
                </div>
                <div class="section-carousel pb-4">
                    @{
                        var thuyetMinh = ViewBag.ThuyetMinh as List<FPTPlay.Models.Movie> ?? new List<FPTPlay.Models.Movie>();
                        foreach(var m in thuyetMinh) {
                            <div class="ls-wrapper" style="width: 250px;">
                                <a href="/Movies/Details/@m.Id" class="ls-card" style="aspect-ratio: 16/9; width: 250px; border-radius: 8px; overflow: hidden; position: relative;">
                                    <img src="@m.PosterUrl" alt="@m.Title" onerror="this.src='/images/default-poster.jpg'" style="width: 100%; height: 100%; object-fit: cover;">
                                </a>
                                <a href="/Movies/Details/@m.Id" class="ls-title fw-bold mt-2 text-white" style="font-size: 0.85rem;">@m.Title</a>
                            </div>
                        }
                    }
                </div>

                <!-- Đại lộ danh vọng Hollywood (Image 2) -->
                <div class="d-flex align-items-center mb-1 mt-4">
                    <h4 class="section-title m-0">Đại lộ danh vọng Hollywood</h4>
                </div>
                <div class="section-carousel pb-5">
                    @{
                        var hollywood = ViewBag.Hollywood as List<FPTPlay.Models.Movie> ?? new List<FPTPlay.Models.Movie>();
                        foreach(var m in hollywood) {
                            <div class="ls-wrapper" style="width: 250px;">
                                <a href="/Movies/Details/@m.Id" class="ls-card" style="aspect-ratio: 16/9; width: 250px; border-radius: 8px; overflow: hidden; position: relative;">
                                    <img src="@m.PosterUrl" alt="@m.Title" onerror="this.src='/images/default-poster.jpg'" style="width: 100%; height: 100%; object-fit: cover;">
                                    @if (!string.IsNullOrEmpty(m.Description))
                                    {
                                        <span style="background: rgba(0,0,0,0.7); color: white; padding: 2px 6px; border-radius: 4px; font-size: 0.75rem; position: absolute; bottom: 8px; right: 8px;"><i class="fas fa-play-circle me-1"></i>@m.Description</span>
                                    }
                                </a>
                                <a href="/Movies/Details/@m.Id" class="ls-title fw-bold mt-2 text-white" style="font-size: 0.85rem;">@m.Title</a>
                            </div>
                        }
                    }
                </div>
            }

            else if (Model == null || !Model.Any())
            {
                <div class="empty-state">
                    <!-- SVG Icon mô phỏng "Không có dữ liệu" -->
                    <div class="empty-icon-wrapper">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="9" y1="15" x2="15" y2="15"></line>
                        </svg>
                        <!-- Kính lúp -->
                        <svg style="position: absolute; bottom: -10px; right: -15px; width: 40px; height: 40px; background: #0c0c0c; border-radius: 50%; padding: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                            <!-- Dấu X trong kính lúp -->
                            <line x1="8" y1="8" x2="14" y2="14" stroke="#ff3c00"></line>
                            <line x1="14" y1="8" x2="8" y2="14" stroke="#ff3c00"></line>
                        </svg>
                        <i class="fas fa-times" style="position: absolute; top: -10px; right: -20px; font-size: 10px; color: #ff3c00; opacity: 0.8;"></i>
                        <i class="fas fa-times" style="position: absolute; bottom: 10px; left: -20px; font-size: 8px; color: #ff3c00; opacity: 0.8;"></i>
                    </div>

                    <h6 class="fw-bold mb-3 mt-3" style="font-size: 1rem;">Mục này chưa có phim nào!</h6>
                    <a href="/" class="btn-return">Khám phá nội dung khác</a>
                </div>
            }
            else
            {
                if (ViewBag.CategoryName == "Truyền hình")
                {
                    <div class="movie-grid-landscape">
                        @foreach (var movie in Model)
                        {
                            <div class="landscape-wrapper">
                                <a href="/Movies/Details/@movie.Id" class="movie-card-landscape">
                                    <img loading="lazy" src="@movie.PosterUrl" alt="@movie.Title" onerror="this.src='/images/default-poster.jpg'" />
                                    <!-- Hiển thị badge LIVE nếu có từ "LIVE" trong description, ngược lại là Hôm nay -->
                                    @if (!string.IsNullOrEmpty(movie.Description) && movie.Description.Contains("LIVE"))
                                    {
                                        <span class="badge-live">LIVE</span>
                                    }
                                    else if (!string.IsNullOrEmpty(movie.Description))
                                    {
                                        <span class="badge-time">Hôm nay lúc @movie.Description</span>
                                    }
                                    else
                                    {
                                        <span class="badge-time">Hôm nay lúc 12:00</span>
                                    }
                                </a>
                                <a href="/Movies/Details/@movie.Id" class="landscape-title">@movie.Title</a>
                            </div>
                        }
                    </div>
                }
                else if (isTvCategory)
                {
                    <div class="channel-grid">
                        @foreach (var movie in Model)
                        {
                            <a href="/Movies/Details/@movie.Id" class="channel-card">
                                <img loading="lazy" src="@movie.PosterUrl" alt="@movie.Title" onerror="this.src='/images/default-poster.jpg'" />
                            </a>
                        }
                    </div>
                }
                else
                {
                    <div class="movie-grid">
                        @foreach (var movie in Model)
                        {
                            <a href="/Movies/Details/@movie.Id" class="movie-card">
                                <img loading="lazy" src="@movie.PosterUrl" alt="@movie.Title" onerror="this.src='/images/default-poster.jpg'" />
                                <div class="title-overlay">@movie.Title</div>
                            </a>
                        }
                    </div>
                }
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Toggle dropdown khi click icon user
        const userIcon = document.getElementById('userIcon');
        const dropdownContent = document.getElementById('userDropdownContent');

        if (userIcon && dropdownContent) {
            userIcon.addEventListener('click', function(e) {
                e.stopPropagation(); // Ngăn click lan ra ngoài
                const isVisible = dropdownContent.style.display === 'block';
                dropdownContent.style.display = isVisible ? 'none' : 'block';
            });

            // Ẩn dropdown khi click ra ngoài
            document.addEventListener('click', function(e) {
                if (!userIcon.contains(e.target) && !dropdownContent.contains(e.target)) {
                    dropdownContent.style.display = 'none';
                }
            });
        }

        // Tìm kiếm chung
        const searchInput = document.getElementById('searchInput');
        if (searchInput) {
            searchInput.addEventListener('input', function(e) {
                const query = e.target.value.trim().toLowerCase();
                const allCards = document.querySelectorAll('.movie-card, .top10-card, .ls-card, .landscape-wrapper, .channel-card');

                allCards.forEach(card => {
                    let text = '';
                    const titleElem = card.querySelector('.title-overlay, .top10-title, .ls-card-title, .landscape-title');
                    
                    if (titleElem) {
                        text = titleElem.textContent.toLowerCase();
                    } else {
                        const img = card.querySelector('img');
                        if (img) text = (img.getAttribute('alt') || '').toLowerCase();
                    }

                    if (query === '' || text.includes(query)) {
                        card.style.display = '';
                    } else {
                        card.style.display = 'none';
                    }
                });
            });
        }

        // Kids Popup Logic
        document.addEventListener('DOMContentLoaded', () => {
            const overlay = document.createElement('div');
            overlay.className = 'overlay-bg';
            document.body.appendChild(overlay);

            window.showKidsPopup = function(cardElem, e) {
                e.preventDefault();
                const popup = cardElem.querySelector('.kids-popup');
                if(popup) {
                    // hide all other popups
                    document.querySelectorAll('.kids-popup.active').forEach(p => p.classList.remove('active'));
                    overlay.classList.add('active');
                    popup.classList.add('active');
                }
            };

            overlay.addEventListener('click', () => {
                document.querySelectorAll('.kids-popup.active').forEach(p => p.classList.remove('active'));
                overlay.classList.remove('active');
            });
        });
    </script>
    <script src="~/js/notifications.js"></script>
</body>
</html>
