@model IEnumerable<FPTPlay.Models.Movie>
@using Microsoft.AspNetCore.Http
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tìm kiếm nâng cao - FPT Play</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <style>
        body { background: #000; color: #e5e5e5; font-family: sans-serif; overflow-x: hidden; }
        .navbar { background: rgba(0,0,0,0.85); border-bottom: 1px solid rgba(255,255,255,0.08); }
        .user-dropdown { position: relative; display: inline-block; }
        .user-dropdown-content { display: none; position: absolute; right: 0; top: 100%; background: #111; min-width: 160px; box-shadow: 0 8px 16px rgba(0,0,0,0.5); border-radius: 8px; z-index: 1055; margin-top: 8px; }
        .user-dropdown-content a { color: white; padding: 12px 16px; text-decoration: none; display: flex; align-items: center; }
        .user-dropdown-content a:hover { background: #222; }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark navbar-expand-lg fixed-top">
        <div class="container-fluid px-3 px-md-4">
            <a class="navbar-brand" href="/">
                <strong style="color: #e50914; font-size: 1.6rem;">FPT Play</strong>
            </a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/AdvancedSearch">Tìm kiếm nâng cao</a></li>
                </ul>
                <div class="d-flex align-items-center gap-3">
                    <div class="user-dropdown">
                        <i id="userIcon" class="fas fa-user-circle fa-2x text-white" style="cursor: pointer;"></i>
                        <div id="userDropdownContent" class="user-dropdown-content">
                            @if (Context.Session.GetString("UserEmail") != null)
                            {
                                <a href="/Home/Profile"><i class="fas fa-info-circle me-2"></i>Thông tin</a>
                                <a href="/Account/Logout"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a>
                            }
                            else
                            {
                                <a href="/Account/Login"><i class="fas fa-sign-in-alt me-2"></i>Đăng nhập</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="container mt-5 pt-5 text-white">
        <h2 class="mb-4 mt-3">Tìm Kiếm Nâng Cao</h2>
        
        <div class="card bg-dark text-white p-4 mb-5 border-secondary" style="background: #111 !important;">
            <form action="/Home/AdvancedSearch" method="get">
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label text-muted">Tên nội dung...</label>
                        <input type="text" name="query" class="form-control bg-black text-white border-secondary" value="@ViewBag.SearchQuery" placeholder="Nhập từ khóa...">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted">Thể loại</label>
                        <select name="categoryId" class="form-select bg-black text-white border-secondary">
                            <option value="">-- Tất cả --</option>
                            @foreach(var cat in ViewBag.CategoriesForSearch)
                            {
                                if (ViewBag.SelectedCategory == cat.Id)
                                {
                                    <option value="@cat.Id" selected>@cat.Name</option>
                                }
                                else
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted">Sắp xếp theo</label>
                        <select name="sortBy" class="form-select bg-black text-white border-secondary">
                            <option value="newest" selected="@(ViewBag.SortBy == "newest" ? "selected" : null)">Mới nhất</option>
                            <option value="oldest" selected="@(ViewBag.SortBy == "oldest" ? "selected" : null)">Cũ nhất</option>
                            <option value="views" selected="@(ViewBag.SortBy == "views" ? "selected" : null)">Lượt xem nhiều nhất</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn fw-bold w-100" style="background: #e50914; color: white;"><i class="fas fa-search me-2"></i>Lọc</button>
                    </div>
                </div>
            </form>
        </div>

        <div class="row g-4">
            @if(Model != null && Model.Any())
            {
                foreach (var movie in Model)
                {
                    <div class="col-6 col-md-3 col-lg-2">
                        <div class="card h-100 bg-transparent border-0 movie-card" onclick="window.location.href='/Movies/Details/@movie.Id'" style="cursor: pointer; transition: transform 0.3s;">
                            <img src="@movie.PosterUrl" class="card-img-top rounded" alt="@movie.Title" style="aspect-ratio: 2/3; object-fit: cover; box-shadow: 0 4px 8px rgba(0,0,0,0.5);">
                            <div class="card-body px-0 py-2">
                                <h6 class="card-title text-truncate text-white mb-1">@movie.Title</h6>
                                <small class="text-secondary"><i class="fas fa-eye me-1"></i>@movie.Views lượt xem</small>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <i class="fas fa-film fa-3x text-secondary mb-3"></i>
                    <h5 class="text-muted">Không tìm thấy nội dung nào phù hợp.</h5>
                </div>
            }
        </div>

        <!-- Phân trang -->
        @if(ViewBag.TotalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-5 mb-5 border-0">
                <ul class="pagination justify-content-center border-0">
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "") border-0">
                            <a class="page-link" style="@(i == ViewBag.CurrentPage ? "background-color: #e50914; color: white; border: none;" : "background-color: #222; color: white; border: none; margin: 0 2px;")" 
                               href="/Home/AdvancedSearch?query=@ViewBag.SearchQuery&categoryId=@ViewBag.SelectedCategory&sortBy=@ViewBag.SortBy&page=@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>

    <script>
        const userIcon = document.getElementById('userIcon');
        const dropdownContent = document.getElementById('userDropdownContent');
        if (userIcon && dropdownContent) {
            userIcon.addEventListener('click', function(e) {
                e.stopPropagation();
                dropdownContent.style.display = dropdownContent.style.display === 'block' ? 'none' : 'block';
            });
            document.addEventListener('click', function(e) {
                if (!userIcon.contains(e.target) && !dropdownContent.contains(e.target)) {
                    dropdownContent.style.display = 'none';
                }
            });
        }
    </script>
</body>
</html>
