@model HomeViewModel
@using FPTPlay.ViewModels

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FPT Play - Trang chủ</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <style>
        :root {
            --primary-red: #e50914;
            --bg-dark: #000;
            --text-light: #e5e5e5;
        }

        body {
            background: var(--bg-dark);
            color: var(--text-light);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            margin: 0;
            overflow-x: hidden;
        }

        .navbar {
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        .movie-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 16px;
            padding: 0 8px;
        }

        .movie-card {
            position: relative;
            border-radius: 8px;
            overflow: hidden;
            background: #111;
            aspect-ratio: 2 / 3;
            transition: transform 0.25s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.25s ease;
            will-change: transform, box-shadow;
            cursor: pointer;
            min-width: 0;
        }

            .movie-card:hover {
                transform: scale(1.08) translateZ(0);
                box-shadow: 0 20px 40px rgba(0,0,0,0.6);
                z-index: 5;
            }

            .movie-card img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
            }

        .title-overlay {
            position: absolute;
            inset: 0 0 0 0;
            background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, transparent 60%);
            display: flex;
            align-items: flex-end;
            padding: 12px 10px;
            font-size: 0.9rem;
            font-weight: 500;
            opacity: 0.95;
            pointer-events: none;
        }

        .badge-ep {
            position: absolute;
            top: 8px;
            right: 8px;
            background: var(--primary-red);
            color: white;
            font-size: 0.75rem;
            padding: 3px 8px;
            border-radius: 4px;
            font-weight: 600;
        }

        .section-title {
            font-size: 1.4rem;
            font-weight: 600;
            margin: 32px 0 16px;
            padding-left: 8px;
        }

        .qr-section {
            background: #0a0a0a;
            padding: 60px 20px;
            text-align: center;
            border-radius: 12px;
            margin: 60px auto;
            max-width: 500px;
        }

            .qr-section img {
                max-width: 180px;
                margin: 20px auto;
                display: block;
            }
        /* Carousel cho phần Cày phim hay mỗi ngày */
        .highlight-carousel {
            display: flex;
            overflow-x: auto;
            gap: 16px;
            padding: 0 8px;
            scroll-behavior: smooth;
            scrollbar-width: thin;
        }

        .highlight-card {
            flex: 0 0 220px;
            position: relative;
            border-radius: 12px;
            overflow: hidden;
            background: #111;
            aspect-ratio: 2 / 3;
            transition: transform 0.3s ease;
            cursor: pointer;
        }

            .highlight-card:hover {
                transform: scale(1.05);
            }

            .highlight-card img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .highlight-title {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
            padding: 20px 12px 12px;
            font-size: 1rem;
            font-weight: 500;
            text-align: center;
        }

        .carousel-arrow {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(0,0,0,0.6);
            color: white;
            border: none;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 10;
        }

            .carousel-arrow.right {
                right: 10px;
            }
        /* Modal chi tiết phim (giống ảnh) */
        .modal-content {
            background: #111;
            color: white;
            border: none;
            border-radius: 16px;
            overflow: hidden;
        }

        .modal-header {
            border-bottom: none;
            position: absolute;
            right: 10px;
            top: 10px;
            z-index: 10;
        }

        .modal-body {
            padding: 0;
        }

        .movie-detail-img {
            width: 100%;
            height: 400px;
            object-fit: cover;
        }

        .movie-info {
            padding: 20px;
        }

        .btn-watch {
            background: var(--primary-red);
            border: none;
            padding: 12px 30px;
            font-size: 1.1rem;
            font-weight: bold;
        }

            .btn-watch:hover {
                background: #c00;
            }

        .rating-star {
            color: #ffc107;
            font-size: 1.2rem;
        }
        /* User dropdown giống ảnh */
        .user-dropdown {
            position: relative;
            display: inline-block;
        }

        .user-dropdown-content {
            display: none;
            position: absolute;
            right: 0;
            top: 100%;
            background: #111;
            min-width: 160px;
            box-shadow: 0 8px 16px rgba(0,0,0,0.5);
            border-radius: 8px;
            z-index: 1055;
            overflow: hidden;
            margin-top: 8px;
        }

            .user-dropdown-content a {
                color: white;
                padding: 12px 16px;
                text-decoration: none;
                display: flex;
                align-items: center;
                transition: background 0.2s;
            }

                .user-dropdown-content a:hover {
                    background: #222;
                }

                .user-dropdown-content a i {
                    margin-right: 10px;
                }

        .dropdown-toggle::after {
            display: none;
        }

    </style>
</head>
<body>

    <!-- Header (giữ nguyên) -->
    <nav class="navbar navbar-dark navbar-expand-lg fixed-top">
        <div class="container-fluid px-3 px-md-4">
            <a class="navbar-brand" href="/">
                <strong style="color: #e50914; font-size: 1.6rem;">FPT Play</strong>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link active" href="/">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/TruyenHinh">Truyền hình</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Category?slug=phim-bo&name=Phim bộ">Phim bộ</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Category?slug=thieu-nhi&name=Thiếu nhi">Thiếu nhi</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Category?slug=ngoai-hang-anh&name=Ngoại hạng Anh">Ngoại hạng Anh</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Xem thêm</a>
                        <ul class="dropdown-menu bg-dark border-0">
                            <li><a class="dropdown-item text-white" href="/Home/Category?slug=phim-le&name=Phim lẻ">Phim lẻ</a></li>
                            <li><a class="dropdown-item text-white" href="/Home/Category?slug=anime&name=Anime">Anime</a></li>
                        </ul>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-3">
                    <input id="searchInput" class="form-control bg-dark text-white border-0" type="search" placeholder="Tìm kiếm..." style="max-width: 180px;" />
                    <i class="fas fa-bell fa-lg text-white" style="cursor: pointer;"></i>

                    <!-- Icon người dùng + dropdown giống ảnh 2 -->
                    <div class="user-dropdown">
                        <i id="userIcon" class="fas fa-user-circle fa-2x text-white" style="cursor: pointer;"></i>
                        <div id="userDropdownContent" class="user-dropdown-content">
                            <a href="/Account/Login"><i class="fas fa-sign-in-alt"></i> Đăng nhập</a>
                            <a href="/Favorites"><i class="fas fa-heart"></i> Yêu thích</a>
                        </div>
                    </div>

                    <a href="#" class="btn btn-danger btn-sm px-3">Mua gói</a>
                </div>
            </div>
        </div>
    </nav>

    <div style="height: 70px;"></div>

    <!-- Banner quảng cáo -->
    <div class="alert alert-warning text-center mb-0 rounded-0 py-3 fw-bold" style="background: linear-gradient(90deg, #ffcc00, #ff9900); color: #000;">
        Quảng cáo • LPBank • Rực rỡ 18 • Đồng hành cùng Khán giả FPT Play • NHẬN ƯU ĐÃI NGAY
    </div>

    <div class="container px-3 px-md-4">
        <h4 class="section-title">Mới ra mắt</h4>
        <div class="movie-grid">
            @foreach (var movie in Model.NewReleases)
            {
                <div class="movie-card" data-bs-toggle="modal" data-bs-target="#movieModal"
                     data-title="@movie.Title"
                     data-poster="@movie.PosterUrl"
                     data-desc="@(movie.Description ?? "Không có mô tả")"
                     data-rating="5.0" data-year="2026" data-episodes="2/10" data-lang="Hàn Quốc" data-quality="FULLHD"
                     data-movie-id="@movie.Id">
                    <img loading="lazy" width="300" height="450" src="@movie.PosterUrl" alt="@movie.Title" onerror="this.src='/images/default-poster.jpg'" />
                    <div class="title-overlay">@movie.Title</div>
                    @if (movie.VideoCount > 0)
                    {
                        <span class="badge-ep">@movie.VideoCount videos</span>
                    }
                    else
                    {
                        <span class="badge-ep">Mới</span>
                    }
                </div>
            }
        </div>

        <h4 class="section-title">Dành riêng cho bạn</h4>
        <div class="movie-grid">
            @foreach (var movie in Model.Personalized)
            {
                <div class="movie-card" data-bs-toggle="modal" data-bs-target="#movieModal"
                     data-title="@movie.Title"
                     data-poster="@movie.PosterUrl"
                     data-desc="@(movie.Description ?? "Không có mô tả")"
                     data-rating="5.0" data-year="2026" data-episodes="2/10" data-lang="Hàn Quốc" data-quality="FULLHD"
                     data-movie-id="@movie.Id">
                    <img loading="lazy" width="300" height="450" src="@movie.PosterUrl" alt="@movie.Title" onerror="this.src='/images/default-poster.jpg'" />
                    <div class="title-overlay">@movie.Title</div>
                </div>
            }
        </div>

        <!-- Phần Cày phim hay mỗi ngày -->
        <h4 class="section-title mt-5">Cày phim hay mỗi ngày <i class="fas fa-chevron-right ms-2" style="font-size: 0.9rem; color: #aaa;"></i></h4>
        <div class="position-relative">
            <div class="highlight-carousel" id="highlightCarousel">
                @foreach (var movie in Model.DailyHighlights)
                {
                    <div class="highlight-card" data-bs-toggle="modal" data-bs-target="#movieModal"
                         data-title="@movie.Title"
                         data-poster="@movie.PosterUrl"
                         data-desc="@(movie.Description ?? "Không có mô tả")"
                         data-rating="3.3" data-year="2012" data-episodes="39/39" data-lang="Trung Quốc" data-quality="FULLHD"
                         data-movie-id="@movie.Id">
                        <img loading="lazy" src="@movie.PosterUrl" alt="@movie.Title" onerror="this.src='/images/default-poster.jpg'" />
                        <div class="highlight-title">@movie.Title</div>
                    </div>
                }
            </div>
            <button class="carousel-arrow right" onclick="document.getElementById('highlightCarousel').scrollBy({left: 240, behavior: 'smooth'})">
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>

        <!-- Phần mới 1: Thể thao -->
        <h4 class="section-title mt-5">Thể thao <i class="fas fa-chevron-right ms-2" style="font-size: 0.9rem; color: #aaa;"></i></h4>
        <div class="position-relative">
            <div class="highlight-carousel" id="sportsCarousel">
                @foreach (var match in Model.SportsHighlights)
                {
                    <div class="highlight-card" style="width: 320px; aspect-ratio: 16/9;" data-bs-toggle="modal" data-bs-target="#movieModal"
                         data-title="@match.Title"
                         data-poster="@match.PosterUrl"
                         data-desc="Ngoại hạng Anh • 2025/26 • 9 phút • Highlights trận đấu"
                         data-rating="4.8" data-year="2026" data-episodes="" data-lang="Premier League" data-quality="4K"
                         data-movie-id="@match.Id">
                        <img loading="lazy" src="@match.PosterUrl" alt="@match.Title" onerror="this.src='/images/default-poster.jpg'" />
                        <div class="highlight-title" style="font-size: 0.95rem;">@match.Title</div>
                    </div>
                }
            </div>
            <button class="carousel-arrow right" onclick="document.getElementById('sportsCarousel').scrollBy({left: 340, behavior: 'smooth'})">
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>

        <!-- Phần mới 2: Điện ảnh Âu Mỹ đỉnh cao -->
        <h4 class="section-title mt-5">Điện ảnh Âu Mỹ đỉnh cao <i class="fas fa-chevron-right ms-2" style="font-size: 0.9rem; color: #aaa;"></i></h4>
        <div class="position-relative">
            <div class="highlight-carousel" id="hollywoodCarousel">
                @foreach (var movie in Model.HollywoodTop)
                {
                    <div class="highlight-card" data-bs-toggle="modal" data-bs-target="#movieModal"
                         data-title="@movie.Title"
                         data-poster="@movie.PosterUrl"
                         data-desc="@(movie.Description ?? "Phim Hollywood đỉnh cao, FULLHD, 4K")"
                         data-rating="5.0" data-year="2010" data-episodes="1h49p" data-lang="Anh" data-quality="FULLHD"
                         data-movie-id="@movie.Id">
                        <img loading="lazy" src="@movie.PosterUrl" alt="@movie.Title" onerror="this.src='/images/default-poster.jpg'" />
                        <div class="highlight-title">@movie.Title</div>
                    </div>
                }
            </div>
            <button class="carousel-arrow right" onclick="document.getElementById('hollywoodCarousel').scrollBy({left: 240, behavior: 'smooth'})">
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>

        <!-- QR section -->
        <div class="qr-section">
            <h5>Tải ứng dụng FPT Play trên thiết bị di động</h5>
            <p>Quét mã QR bên dưới</p>
            <img loading="lazy" src="https://api.qrserver.com/v1/create-qr-code/?data=https://fptplay.vn/app&size=200x200" alt="QR Code tải FPT Play" />
        </div>
    </div>

    <!-- Modal chi tiết phim (giống ảnh bạn gửi) -->
    <div class="modal fade" id="movieModal" tabindex="-1" aria-labelledby="movieModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0 position-absolute top-0 end-0 z-10" style="z-index: 1050;">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="row g-0">
                        <div class="col-md-5 col-lg-4 d-flex align-items-center justify-content-center bg-black">
                            <img id="modalPoster" class="img-fluid" style="width: 100%; max-height: 600px; object-fit: contain; background: #000;" src="" alt="Poster phim">
                        </div>
                        <div class="col-md-7 col-lg-8">
                            <div class="movie-info p-4 p-md-5">
                                <h2 id="modalTitle" class="mb-3"></h2>
                                <div class="mb-4">
                                    <span class="rating-star me-3"><i class="fas fa-star"></i> <span id="modalRating"></span></span>
                                    <span id="modalQuality" class="me-3 fw-bold"></span>
                                    <span id="modalYear"></span> • <span id="modalEpisodes"></span> • <span id="modalLang"></span>
                                </div>
                                <p id="modalDesc" class="lead text-secondary"></p>
                                <div class="d-flex flex-wrap gap-3 mt-5">
                                    <a id="watchNowBtn" class="btn btn-watch btn-lg" href="#">
                                        <i class="fas fa-play me-2"></i>Xem ngay
                                    </a>
                                    <button id="btnFavorite" class="btn btn-outline-light btn-lg">
                                        <i class="fas fa-heart me-2"></i>Yêu thích
                                    </button>
                                    <button class="btn btn-outline-light btn-lg"><i class="fas fa-share-alt me-2"></i>Chia sẻ</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    <script>
        let currentMovieId = 0;

        // JS để điền dữ liệu vào modal khi click card
        document.querySelectorAll('.movie-card, .highlight-card').forEach(card => {
            card.addEventListener('click', function () {
                const modal = document.getElementById('movieModal');
                currentMovieId = parseInt(this.dataset.movieId) || 0;

                modal.querySelector('#modalTitle').textContent = this.dataset.title;
                modal.querySelector('#modalPoster').src = this.dataset.poster;
                modal.querySelector('#modalDesc').textContent = this.dataset.desc;
                modal.querySelector('#modalRating').textContent = this.dataset.rating;
                modal.querySelector('#modalYear').textContent = this.dataset.year;
                modal.querySelector('#modalEpisodes').textContent = this.dataset.episodes;
                modal.querySelector('#modalLang').textContent = this.dataset.lang;
                modal.querySelector('#modalQuality').textContent = this.dataset.quality;

                // Lưu id phim và cập nhật link Xem ngay
                const watchBtn = modal.querySelector('#watchNowBtn');
                watchBtn.href = '/Movies/Details/' + currentMovieId;

                // Cập nhật nút Yêu thích
                const favBtn = modal.querySelector('#btnFavorite');
                favBtn.onclick = function() {
                    window.location.href = '/Favorites/Add/' + currentMovieId;
                };
            });
        });

            // Tìm kiếm phim
        document.getElementById('searchInput').addEventListener('input', function(e) {
            const query = e.target.value.trim().toLowerCase();
            const allCards = document.querySelectorAll('.movie-card, .highlight-card');

            allCards.forEach(card => {
                const title = card.querySelector('.title-overlay, .highlight-title');
                if (title) {
                    const text = title.textContent.toLowerCase();
                    if (query === '' || text.includes(query)) {
                        card.style.display = 'block';
                        card.style.opacity = '1';
                        card.style.height = 'auto';
                    } else {
                        card.style.display = 'none';
                        card.style.opacity = '0';
                        card.style.height = '0';
                    }
                }
            });
        });

            // Toggle dropdown khi click icon user
        const userIcon = document.getElementById('userIcon');
        const dropdownContent = document.getElementById('userDropdownContent');

        if (userIcon && dropdownContent) {
            userIcon.addEventListener('click', function(e) {
                e.stopPropagation(); // Ngăn click lan ra ngoài
                const isVisible = dropdownContent.style.display === 'block';
                dropdownContent.style.display = isVisible ? 'none' : 'block';
            });

            // Ẩn dropdown khi click ra ngoài
            document.addEventListener('click', function(e) {
                if (!userIcon.contains(e.target) && !dropdownContent.contains(e.target)) {
                    dropdownContent.style.display = 'none';
                }
            });
        }

    </script>
</body>
</html>