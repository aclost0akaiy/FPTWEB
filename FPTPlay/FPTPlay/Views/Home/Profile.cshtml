@model FPTPlay.Models.User
@{
    Layout = null;
}
@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Thông tin tài khoản - FPT Play</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <style>
        body {
            background-color: #0f1014;
            color: #fff;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            margin: 0;
            padding: 50px 20px;
        }

        .profile-container {
            max-width: 700px;
            margin: 0 auto;
        }

        .profile-title {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 30px;
        }

        .info-item {
            background-color: #1a1a1a;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 20px;
            font-size: 0.95rem;
            margin-bottom: 12px;
        }

        .info-label {
            color: #d1d1d1;
            width: 200px;
            flex-shrink: 0;
        }

        .info-value {
            color: #fff;
            flex-grow: 1;
            font-weight: bold;
        }

        .back-btn {
            color: #fff;
            text-decoration: none;
            display: inline-block;
            margin-bottom: 20px;
            font-size: 0.95rem;
            opacity: 0.8;
            transition: opacity 0.2s;
        }

        .back-btn:hover {
            opacity: 1;
        }
    </style>
</head>
<body>
    <div class="profile-container">
        <a href="/" class="back-btn">
            <i class="fas fa-arrow-left me-2"></i> Trở về Trang chủ
        </a>

        <h2 class="profile-title">Thông tin tài khoản</h2>

        <div class="info-item">
            <div class="info-label">Tên tài khoản</div>
            <div class="info-value">@Model.Email</div>
        </div>

        <div class="info-item">
            <div class="info-label">Họ và tên</div>
            <div class="info-value">@(string.IsNullOrEmpty(Model.FullName) ? "Chưa cập nhật" : Model.FullName)</div>
        </div>
        
        <div class="info-item">
            <div class="info-label">UID</div>
            <div class="info-value">0@(Model.Id)</div>
        </div>
        
        <div class="info-item">
            <div class="info-label">Số điện thoại</div>
            <div class="info-value">@(string.IsNullOrEmpty(Model.Phone) ? "Chưa cập nhật" : Model.Phone)</div>
        </div>

        <div class="info-item" style="cursor: pointer;">
            <div class="info-label">Mã quản lý</div>
            <div class="info-value">••••••</div>
            <div><i class="fas fa-chevron-right text-muted" style="font-size: 0.8rem;"></i></div>
        </div>
    </div>
</body>
</html>
