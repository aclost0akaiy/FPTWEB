@model FPTPlay.Models.User
@{
    Layout = null;
}
@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Thông tin tài khoản - FPT Play</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <style>
        body {
            background-color: #0f1014;
            color: #fff;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            margin: 0;
            padding: 50px 20px;
        }

        .profile-container {
            max-width: 700px;
            margin: 0 auto;
        }

        .profile-title {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 30px;
        }

        .info-item {
            background-color: #1a1a1a;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 20px;
            font-size: 0.95rem;
            margin-bottom: 12px;
        }

        .info-label {
            color: #d1d1d1;
            width: 200px;
            flex-shrink: 0;
        }

        .info-value {
            color: #fff;
            flex-grow: 1;
            font-weight: bold;
        }

        .back-btn {
            color: #fff;
            text-decoration: none;
            display: inline-block;
            margin-bottom: 20px;
            font-size: 0.95rem;
            opacity: 0.8;
            transition: opacity 0.2s;
        }

        .back-btn:hover {
            opacity: 1;
        }
    </style>
</head>
<body>
    <div class="profile-container">
        <a href="/" class="back-btn">
            <i class="fas fa-arrow-left me-2"></i> Trở về Trang chủ
        </a>

        <h2 class="profile-title">Thông tin tài khoản</h2>

        <!-- Khu vực Avatar -->
        <div class="text-center mb-4">
            <img src="@(Model.AvatarUrl ?? "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(Model.FullName ?? Model.Email) + "&background=random")" alt="Avatar" class="rounded-circle mb-3 border border-secondary" style="width: 120px; height: 120px; object-fit: cover;" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.FullName ?? Model.Email)&background=random';" />
            <form action="/Home/UploadAvatar" method="post" enctype="multipart/form-data">
                <input type="file" name="avatarFile" accept="image/*" class="d-none" id="avatarInput" onchange="this.form.submit()" />
                <button type="button" class="btn btn-sm" style="background: rgba(255,255,255,0.1); color: #fff; border: none; padding: 6px 15px; border-radius: 20px;" onclick="document.getElementById('avatarInput').click()"><i class="fas fa-camera"></i> Đổi ảnh đại diện</button>
            </form>
        </div>

        <div class="info-item">
            <div class="info-label">Tên tài khoản</div>
            <div class="info-value">@Model.Email</div>
        </div>

        <div class="info-item">
            <div class="info-label">Họ và tên</div>
            <div class="info-value">@(string.IsNullOrEmpty(Model.FullName) ? "Chưa cập nhật" : Model.FullName)</div>
        </div>
        
        <div class="info-item">
            <div class="info-label">UID</div>
            <div class="info-value">0@(Model.Id)</div>
        </div>
        
        <div class="info-item">
            <div class="info-label">Số điện thoại</div>
            <div class="info-value">@(string.IsNullOrEmpty(Model.Phone) ? "Chưa cập nhật" : Model.Phone)</div>
        </div>

        <div class="info-item" style="cursor: pointer;">
            <div class="info-label">Mã quản lý</div>
            <div class="info-value">••••••</div>
            <div><i class="fas fa-chevron-right text-muted" style="font-size: 0.8rem;"></i></div>
        </div>

        <h3 class="profile-title mt-5 mb-3" style="font-size: 1.3rem;">Lịch sử xem phim</h3>
        <div class="history-list">
            @if(ViewBag.WatchHistories != null && ((IEnumerable<dynamic>)ViewBag.WatchHistories).Any())
            {
                foreach(var history in ViewBag.WatchHistories)
                {
                    <div class="info-item" style="padding: 10px 20px;">
                        <img src="@history.Movie.PosterUrl" style="width: 50px; height: 75px; object-fit: cover; border-radius: 4px; margin-right: 15px;" />
                        <div class="info-value">
                            <a href="/Movies/Details/@history.MovieId" style="color: #fff; text-decoration: none; display: block; margin-bottom: 5px;">@history.Movie.Title</a>
                            <small class="text-muted" style="font-weight: normal;">Đã xem lúc: @history.WatchedAt.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="info-item" style="justify-content: center; color: #aaa;">Chưa có lịch sử xem phim.</div>
            }
        </div>
    </div>
</body>
</html>
