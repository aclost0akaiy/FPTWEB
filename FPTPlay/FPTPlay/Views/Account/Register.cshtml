@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký - FPT Play</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <style>
        body {
            background-color: #000;
            background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.9)), url('https://fptplay.vn/images/bg_home.png');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            color: #fff;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            margin: 0;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            position: relative;
        }

        .login-wrapper {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 420px;
            padding: 20px;
            text-align: center;
        }

        .login-logo {
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .login-logo i {
            font-size: 1.5rem;
            color: #fff;
            background: #f15a24;
            width: 45px;
            height: 45px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding-left: 4px;
        }

        .login-logo span {
            font-size: 1.8rem;
            font-weight: 700;
            color: #fff;
        }

        .login-box {
            background: #222;
            border-radius: 12px;
            padding: 30px;
            text-align: left;
            box-shadow: 0 10px 40px rgba(0,0,0,0.8);
        }

        .login-title {
            font-size: 1.15rem;
            font-weight: bold;
            margin-bottom: 25px;
            color: #fff;
        }

        .form-control-custom {
            background: rgba(0,0,0,0.2);
            border: 1px solid #444;
            color: #fff;
            padding: 12px 18px;
            border-radius: 25px;
            width: 100%;
            margin-bottom: 20px;
            transition: all 0.3s;
        }

        .form-control-custom::placeholder {
            color: #888;
        }

        .form-control-custom:focus {
            outline: none;
            border-color: #f15a24;
            background: rgba(0,0,0,0.4);
            box-shadow: 0 0 0 2px rgba(241, 90, 36, 0.2);
        }

        .btn-continue {
            background: #f15a24;
            color: #fff;
            border: none;
            padding: 12px;
            border-radius: 25px;
            width: 100%;
            font-weight: bold;
            font-size: 1rem;
            margin-bottom: 20px;
            transition: background 0.3s;
        }

        .btn-continue:hover {
            background: #e04810;
            color: #fff;
        }

        .terms-checkbox {
            display: flex;
            align-items: flex-start;
            font-size: 0.8rem;
            color: #ccc;
        }

        .terms-checkbox input[type="checkbox"] {
            appearance: none;
            -webkit-appearance: none;
            min-width: 16px;
            height: 16px;
            border: 1px solid #f15a24;
            border-radius: 3px;
            background-color: #f15a24;
            display: inline-block;
            position: relative;
            margin-right: 10px;
            margin-top: 2px;
            cursor: pointer;
        }

        .terms-checkbox input[type="checkbox"]:checked::after {
            content: '\f00c';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            font-size: 10px;
            color: white;
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        .terms-checkbox a {
            color: #f15a24;
            text-decoration: none;
        }

        .terms-checkbox a:hover {
            text-decoration: underline;
        }

        .close-btn {
            position: absolute;
            top: 30px;
            right: 30px;
            color: #fff;
            font-size: 1.8rem;
            text-decoration: none;
            z-index: 20;
            opacity: 0.7;
            transition: opacity 0.3s;
            background: rgba(255,255,255,0.1);
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
        }

        .close-btn:hover {
            opacity: 1;
            color: #fff;
            background: rgba(255,255,255,0.2);
        }
        
    </style>
</head>
<body>
    <a href="/" class="close-btn"><i class="fas fa-times"></i></a>
    
    <div class="login-wrapper">
        <div class="login-logo">
            <i class="fas fa-play"></i> 
            <span>FPT Play</span>
        </div>

        <div class="login-box">
            <div class="login-title">Đăng ký tài khoản</div>
            
            <form action="/Account/Register" method="post">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger" style="border-radius: 20px; font-size: 0.9rem; padding: 10px;">@ViewBag.Error</div>
                }
                <input type="text" name="fullName" class="form-control-custom" placeholder="Họ và tên" required />
                <input type="email" name="email" class="form-control-custom" placeholder="Gmail" required />
                <input type="tel" name="phone" class="form-control-custom" placeholder="Số điện thoại" required />
                <input type="password" name="password" class="form-control-custom" placeholder="Mật khẩu" required style="margin-bottom: 25px;" />
                
                <button type="submit" class="btn-continue">Xác nhận</button>
                
                <div class="text-center my-3 text-muted" style="position: relative;">
                    <hr style="border-color: #444;" />
                    <span style="position: absolute; top: -10px; left: 50%; transform: translateX(-50%); background: #222; padding: 0 10px; font-size: 0.85rem;">HOẶC ĐĂNG NHẬP BẰNG</span>
                </div>

                <a href="/Account/GoogleLogin" class="btn btn-outline-light w-100 mb-4" style="border-radius: 25px; padding: 10px; font-weight: bold; font-size: 1rem; border-color: #555;">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/5/53/Google_%22G%22_Logo.svg" alt="Google" style="width: 20px; height: 20px; margin-right: 8px;"> Google
                </a>
                
                <div class="d-flex justify-content-between mb-4" style="font-size: 0.9rem;">
                    <a href="/Account/Login" style="color: #f15a24; text-decoration: none;">Đã có tài khoản? Đăng nhập</a>
                </div>
                
                <div class="terms-checkbox">
                    <input type="checkbox" checked required id="terms" />
                    <label for="terms" style="cursor: pointer;">Tôi đã đọc và đồng ý với <a href="#">Điều khoản sử dụng FPT Play</a></label>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
