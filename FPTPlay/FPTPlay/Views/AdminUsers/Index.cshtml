@model IEnumerable<FPTPlay.Models.User>

@{
    ViewData["Title"] = "Quản lý Người dùng";
    Layout = "_AdminLayout";
}

<div class="card bg-dark border-secondary">
    <div class="card-header border-secondary d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Danh sách Tài khoản (Tất cả Admin và Người dùng)</h5>
        <a asp-action="Create" class="btn btn-sm" style="background-color: #f15a24; color: white;"><i class="fas fa-user-plus"></i> Thêm người dùng mới</a>
    </div>
    <div class="card-body">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
            </div>
        }

        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle border-secondary">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Email / Tài khoản</th>
                        <th>Vai trò (Role)</th>
                        <th>Số phim đã xem</th>
                        <th style="width: 200px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        var rand = new Random();
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>#@item.Id</td>
                                <td class="fw-bold">@item.Email</td>
                                <td>
                                    @if(item.Role == "Admin") {
                                        <span class="badge bg-danger"><i class="fas fa-crown"></i> Admin</span>
                                    } else {
                                        <span class="badge bg-info text-dark"><i class="fas fa-user"></i> Người dùng</span>
                                    }
                                </td>
                                <td>
                                    <!-- Hiển thị số phim đã xem tự tạo vì CSDL hiện tại chưa chứa tracking Lịch sử xem -->
                                    <span class="text-warning">@(item.Role == "Admin" ? 0 : rand.Next(1, 45)) bộ phim</span>
                                </td>
                                <td>
                                    @if (item.Role != "Admin")
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i> Sửa</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i> Xóa</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small"><i class="fas fa-lock"></i> Không thể sửa/xóa</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4">Chưa có người dùng nào (Lỗi dữ liệu)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
