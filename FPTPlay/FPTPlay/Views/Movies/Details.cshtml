@model FPTPlay.Models.Movie
@using Microsoft.AspNetCore.Http
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Title - FPT Play</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <style>
        :root {
            --primary-red: #e50914;
            --bg-dark: #000;
            --text-light: #e5e5e5;
        }

        body {
            background: var(--bg-dark);
            color: var(--text-light);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            margin: 0;
            overflow-x: hidden;
        }

        .navbar {
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        .player-wrapper {
            margin-top: 56px; /* navbar height */
            width: 100%;
            background: #000;
        }

        .player-container {
            max-width: 1200px;
            margin: 0 auto;
            aspect-ratio: 16 / 9;
            background: #111;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .movie-info-container {
            max-width: 1200px;
            margin: 40px auto;
            padding: 0 20px;
            display: flex;
            gap: 40px;
        }

        .movie-poster {
            flex: 0 0 250px;
        }

            .movie-poster img {
                width: 100%;
                border-radius: 12px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.8);
            }

        .movie-details {
            flex: 1;
        }

        .movie-title {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 15px;
        }

        .meta-tags {
            display: flex;
            gap: 15px;
            align-items: center;
            margin-bottom: 25px;
            color: #aaa;
            font-size: 1rem;
        }

        .quality-badge {
            background: #fff;
            color: #000;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.85rem;
            font-weight: 700;
        }

        .btn-action {
            padding: 12px 30px;
            border-radius: 8px;
            font-weight: bold;
            font-size: 1.1rem;
            transition: all 0.2s;
            border: none;
        }

        .btn-play {
            background: var(--primary-red);
            color: white;
        }

            .btn-play:hover {
                background: #c00;
                color: white;
            }

        .btn-outline-custom {
            background: rgba(255,255,255,0.1);
            color: white;
            border: 1px solid rgba(255,255,255,0.3);
        }

            .btn-outline-custom:hover {
                background: rgba(255,255,255,0.2);
                color: white;
            }

        .description {
            font-size: 1.1rem;
            line-height: 1.6;
            color: #ccc;
            margin-top: 30px;
        }

        /* User dropdown */
        .user-dropdown {
            position: relative;
            display: inline-block;
        }

        .user-dropdown-content {
            display: none;
            position: absolute;
            right: 0;
            top: 100%;
            background: #111;
            min-width: 160px;
            box-shadow: 0 8px 16px rgba(0,0,0,0.5);
            border-radius: 8px;
            z-index: 1055;
            overflow: hidden;
            margin-top: 8px;
        }

            .user-dropdown-content a {
                color: white;
                padding: 12px 16px;
                text-decoration: none;
                display: flex;
                align-items: center;
                transition: background 0.2s;
            }

                .user-dropdown-content a:hover {
                    background: #222;
                }

                .user-dropdown-content a i {
                    margin-right: 10px;
                }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container-fluid px-3 px-md-4">
            <a class="navbar-brand" href="/">
                <strong style="color: #e50914; font-size: 1.6rem;">FPT Play</strong>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Truyền hình</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Phim bộ</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Thiếu nhi</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Ngoại hạng Anh</a></li>
                </ul>
                <div class="d-flex align-items-center gap-3">
                    <div class="user-dropdown">
                        <i id="userIcon" class="fas fa-user-circle fa-2x text-white" style="cursor: pointer;"></i>
                        <div id="userDropdownContent" class="user-dropdown-content">
                            @if (Context.Session.GetString("UserEmail") != null)
                            {
                                <a href="/Account/Logout"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a>
                                <a href="/Favorites"><i class="fas fa-heart"></i> Yêu thích</a>
                                <a href="/Home/Profile"><i class="fas fa-info-circle"></i> Thông tin tài khoản</a>
                            }
                            else
                            {
                                <a href="/Account/Login"><i class="fas fa-sign-in-alt"></i> Đăng nhập</a>
                                <a href="/Account/Register"><i class="fas fa-user-plus"></i> Đăng ký</a>
                            }
                        </div>
                    </div>
                    <a href="/Home/MuaGoi" class="btn btn-danger btn-sm px-3">Mua gói</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Player -->
    <div class="player-wrapper">
        <div class="player-container">
            @if (!string.IsNullOrEmpty(Model.VideoUrl))
            {
                <video controls width="100%" height="100%" poster="@Model.PosterUrl" style="object-fit: contain; outline: none;">
                    <source src="@Model.VideoUrl" type="video/mp4" />
                    Trình duyệt của bạn không hỗ trợ video player.
                </video>
            }
            else
            {
                <div style="width: 100%; height: 100%; background: url('@Model.PosterUrl') center/cover; position: relative; display: flex; align-items: center; justify-content: center;">
                    <div style="position: absolute; inset: 0; background: rgba(0,0,0,0.7);"></div>
                    <div style="position: relative; z-index: 1; text-align: center;">
                        <i class="fas fa-play-circle mb-3" style="font-size: 5rem; color: rgba(255,255,255,0.7); cursor: pointer;"></i>
                        <h4 class="text-white-50 mt-2">Đang tải video...</h4>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Info -->
    <div class="movie-info-container">
        <div class="movie-poster d-none d-md-block">
            <img src="@Model.PosterUrl" alt="@Model.Title" onerror="this.src='/images/default-poster.jpg'" />
        </div>
        <div class="movie-details">
            <h1 class="movie-title">@Model.Title</h1>
            <div class="meta-tags">
                <span style="color: #ffc107;"><i class="fas fa-star me-1"></i>5.0</span>
                <span>@Model.CreatedDate.Year</span>
                <span class="quality-badge">FULLHD</span>
                @if (Model.Category != null)
                {
                    <span>• @Model.Category.Name</span>
                }
                @if (Model.Duration.HasValue)
                {
                    <span>• @Model.Duration phút</span>
                }
                else
                {
                    <span>• 120 phút</span>
                }
            </div>

            <div class="d-flex gap-3 mb-4 mt-4">
                <button class="btn btn-action btn-play">
                    <i class="fas fa-play me-2"></i>Xem Phim
                </button>
                <button class="btn btn-action btn-outline-custom">
                    <i class="fas fa-plus me-2"></i>Lưu lại
                </button>
            </div>

            <div class="description">
                @(string.IsNullOrEmpty(Model.Description) ? "Bộ phim này hiện chưa có mô tả chi tiết. Hãy cùng thưởng thức để khám phá nội dung hấp dẫn nhé!" : Model.Description)
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const userIcon = document.getElementById('userIcon');
        const dropdownContent = document.getElementById('userDropdownContent');

        if (userIcon && dropdownContent) {
            userIcon.addEventListener('click', function (e) {
                e.stopPropagation();
                const isVisible = dropdownContent.style.display === 'block';
                dropdownContent.style.display = isVisible ? 'none' : 'block';
            });

            document.addEventListener('click', function (e) {
                if (!userIcon.contains(e.target) && !dropdownContent.contains(e.target)) {
                    dropdownContent.style.display = 'none';
                }
            });
        }
    </script>
</body>
</html>
