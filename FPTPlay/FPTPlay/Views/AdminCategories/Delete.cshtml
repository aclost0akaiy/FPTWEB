@model FPTPlay.Models.Category

@{
    ViewData["Title"] = "Xác nhận Xóa Danh mục";
    Layout = "_AdminLayout";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card bg-dark border-danger">
            <div class="card-header border-danger bg-danger text-white">
                <h5 class="mb-0"><i class="fas fa-exclamation-triangle"></i> CẢNH BÁO XÓA DANH MỤC</h5>
            </div>
            <div class="card-body text-center">
                <h4 class="text-white mb-3">@Model.Name</h4>
                <p class="text-secondary">Slug: @Model.Slug</p>
                <div class="alert alert-warning text-dark">
                    <strong>Lưu ý:</strong> Việc xóa danh mục này có thể khiến các bản ghi phim/chương trình thuộc danh mục này bị mồ côi (lỗi bảng). Hãy cân nhắc kỹ!
                </div>
                
                <form asp-action="Delete" class="mt-4">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger btn-lg px-4"><i class="fas fa-trash"></i> Xóa danh mục ngay</button>
                    <a asp-action="Index" class="btn btn-outline-light btn-lg px-4 ms-2">Không, quay lại</a>
                </form>
            </div>
        </div>
    </div>
</div>
