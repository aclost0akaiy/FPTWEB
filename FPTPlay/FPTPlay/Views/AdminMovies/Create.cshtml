@model FPTPlay.Models.Movie

@{
    ViewData["Title"] = "Thêm phim mới";
    Layout = "_AdminLayout";
}

<div class="card bg-dark border-secondary">
    <div class="card-header border-secondary">
        <h5 class="mb-0">Thêm phim mới</h5>
    </div>
    <div class="card-body">
        <form asp-action="Create" enctype="multipart/form-data">
            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Tên phim</label>
                        <input asp-for="Title" class="form-control bg-dark text-white border-secondary" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Mô tả</label>
                        <textarea asp-for="Description" class="form-control bg-dark text-white border-secondary" rows="4"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CategoryId" class="form-label">Mục để phim (Truyền hình, Phim bộ...)</label>
                            <select asp-for="CategoryId" class="form-select bg-dark text-white border-secondary" asp-items="ViewBag.CategoryId" required>
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Tải lên Video (Tuỳ chọn)</label>
                            <input type="file" name="videoFile" accept="video/mp4,video/x-m4v,video/*" class="form-control bg-dark text-white border-secondary" />
                            <input type="hidden" asp-for="VideoUrl" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Duration" class="form-label">Thời lượng (phút)</label>
                            <input asp-for="Duration" type="number" class="form-control bg-dark text-white border-secondary" />
                        </div>
                    </div>
                    <div class="mb-3 form-check">
                        <input asp-for="IsNewRelease" class="form-check-input" />
                        <label asp-for="IsNewRelease" class="form-check-label text-warning fw-bold">Luôn hiện trong trang chủ (Mới ra mắt)</label>
                    </div>
                    <div class="mb-3 form-check">
                        <input asp-for="IsPersonalized" class="form-check-input" />
                        <label asp-for="IsPersonalized" class="form-check-label text-info fw-bold">Hiện trong mục "Dành riêng cho bạn"</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label">Tải lên Hình ảnh (Poster)</label>
                        <input type="file" name="posterFile" accept="image/*" class="form-control bg-dark text-white border-secondary" id="posterInput" onchange="previewPoster(this)" />
                        <input type="hidden" asp-for="PosterUrl" value="/images/default-poster.jpg" />
                    </div>
                    <div class="text-center p-3 border border-secondary rounded bg-black">
                        <img id="posterPreview" src="/images/default-poster.jpg" alt="Preview" class="img-fluid rounded" style="max-height: 300px; object-fit: cover;" onerror="this.src='/images/default-poster.jpg'" />
                    </div>
                </div>
            </div>
            <div class="mt-4 border-top border-secondary pt-3">
                <button type="submit" class="btn btn-primary" style="background-color: #f15a24; border: none;"><i class="fas fa-save"></i> Lưu thông tin phim</button>
                <a asp-action="Index" class="btn btn-outline-light ms-2">Hủy bỏ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function previewPoster(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('posterPreview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            } else {
                document.getElementById('posterPreview').src = '/images/default-poster.jpg';
            }
        }
    </script>
}
