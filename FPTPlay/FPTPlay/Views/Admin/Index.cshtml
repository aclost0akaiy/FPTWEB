@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
}

<style>
    .stat-card {
        background: #25262b;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid #373a40;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .stat-icon {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        background: rgba(241, 90, 36, 0.1);
        color: #f15a24;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
    }

    .stat-info h3 {
        margin: 0;
        font-size: 1.8rem;
        font-weight: bold;
    }

    .stat-info p {
        margin: 0;
        color: #adb5bd;
        font-size: 0.9rem;
    }
</style>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-info">
                <p>Tổng số Phim</p>
                <h3>@ViewBag.TotalMovies</h3>
            </div>
            <div class="stat-icon"><i class="fas fa-film"></i></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-info">
                <p>Danh mục</p>
                <h3>@ViewBag.TotalCategories</h3>
            </div>
            <div class="stat-icon"><i class="fas fa-list"></i></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-info">
                <p>Người dùng</p>
                <h3>@ViewBag.TotalUsers</h3>
            </div>
            <div class="stat-icon"><i class="fas fa-users"></i></div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card bg-dark border-secondary h-100">
            <div class="card-header border-secondary d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-history text-warning me-2"></i> Phim mới thêm đầy đây</h5>
                <a href="/AdminMovies" class="btn btn-sm btn-outline-light">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-dark table-hover mb-0 align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Tiêu đề / Poster</th>
                                <th>Danh mục</th>
                                <th>Ngày đăng</th>
                                <th>Trang chủ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if(ViewBag.RecentMovies != null) {
                                foreach(var item in ViewBag.RecentMovies) {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div style="width: 40px; height: 60px; background: #000; border-radius: 4px; overflow: hidden; display: flex; align-items: center; justify-content: center;" class="me-3">
                                                    <img src="@item.PosterUrl" style="max-height: 100%; max-width: 100%; object-fit: contain;" alt="Poster" onerror="this.src='/images/default-poster.jpg'" />
                                                </div>
                                                <span class="fw-bold">@item.Title</span>
                                            </div>
                                        </td>
                                        <td><span class="badge bg-secondary">@(item.Category?.Name ?? "N/A")</span></td>
                                        <td class="text-secondary">@item.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            @if(item.IsNewRelease) {
                                                <i class="fas fa-check-circle text-success"></i>
                                            } else {
                                                <i class="fas fa-minus-circle text-secondary"></i>
                                            }
                                        </td>
                                    </tr>
                                }
                            } else {
                                <tr><td colspan="4" class="text-center py-4 text-secondary">Chưa có hoạt động nào được ghi nhận.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <!-- Quick Actions -->
        <div class="card bg-dark border-secondary mb-4">
            <div class="card-header border-secondary">
                <h5 class="mb-0"><i class="fas fa-bolt text-danger me-2"></i> Thao tác nhanh</h5>
            </div>
            <div class="card-body p-3">
                <div class="d-grid gap-2">
                    <a href="/AdminMovies/Create" class="btn btn-primary" style="background-color: #f15a24; border: none;"><i class="fas fa-plus-circle me-2"></i> Thêm phim mới</a>
                    <a href="/AdminCategories/Create" class="btn btn-outline-info"><i class="fas fa-folder-plus me-2"></i> Tạo danh mục</a>
                </div>
            </div>
        </div>

        <!-- Top Categories -->
        <div class="card bg-dark border-secondary">
            <div class="card-header border-secondary">
                <h5 class="mb-0"><i class="fas fa-chart-pie text-info me-2"></i> Tỷ trọng Thể loại</h5>
            </div>
            <div class="card-body p-3">
                @if(ViewBag.CategoryStats != null) {
                    var maxCount = ViewBag.TotalMovies > 0 ? (int)ViewBag.TotalMovies : 1;
                    foreach(var stat in ViewBag.CategoryStats) {
                        var percent = (int)(Math.Round((double)(stat.Count * 100) / maxCount));
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-light">@stat.Name</span>
                                <span class="text-secondary small">@stat.Count phim</span>
                            </div>
                            <div class="progress" style="height: 6px; background-color: #373a40;">
                                <div class="progress-bar" role="progressbar" style="width: @percent%; background-color: #f15a24;" aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                    }
                }
                
                <div class="alert alert-dark border-secondary mt-4 mb-0 text-center d-flex align-items-center justify-content-center flex-column">
                    <i class="fas fa-fire text-warning mb-2 h3"></i>
                    <h5 class="mb-1">@ViewBag.NewReleasesCount Phim</h5>
                    <small class="text-muted">Đang được ghim lên Trang Chủ</small>
                </div>
            </div>
        </div>
    </div>
</div>
