@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FPT Play - Trang Quản Trị</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <style>
        body {
            background-color: #1a1b1e;
            color: #fff;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            margin: 0;
            overflow-x: hidden;
        }

        .sidebar {
            width: 250px;
            height: 100vh;
            background: #25262b;
            position: fixed;
            top: 0;
            left: 0;
            padding-top: 20px;
            border-right: 1px solid #373a40;
        }

        .sidebar-logo {
            text-align: center;
            margin-bottom: 30px;
            padding: 0 20px;
        }

        .sidebar-logo i {
            color: #f15a24;
            font-size: 2rem;
            margin-right: 10px;
            vertical-align: middle;
        }

        .sidebar-logo span {
            font-size: 1.5rem;
            font-weight: bold;
            color: #fff;
            vertical-align: middle;
        }

        .nav-link {
            color: #adb5bd;
            padding: 12px 20px;
            margin: 4px 15px;
            border-radius: 8px;
            transition: all 0.3s;
        }

        .nav-link:hover, .nav-link.active {
            background: #f15a24;
            color: #fff;
        }

        .nav-link i {
            margin-right: 10px;
            width: 20px;
            text-align: center;
        }

        .main-content {
            margin-left: 250px;
            padding: 20px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 20px;
            border-bottom: 1px solid #373a40;
            margin-bottom: 20px;
        }
        
        .stat-card {
            background: #25262b;
            border-radius: 12px;
            padding: 20px;
            border: 1px solid #373a40;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            background: rgba(241, 90, 36, 0.1);
            color: #f15a24;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
        }

        .stat-info h3 {
            margin: 0;
            font-size: 1.8rem;
            font-weight: bold;
        }

        .stat-info p {
            margin: 0;
            color: #adb5bd;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="sidebar-logo">
            <i class="fas fa-play-circle" style="background: #fff; border-radius: 50%; padding: 2px;"></i>
            <span>Admin Panel</span>
        </div>
        <div class="nav flex-column">
            <a href="/Admin" class="nav-link active"><i class="fas fa-tachometer-alt"></i> Tổng quan</a>
            <a href="#" class="nav-link"><i class="fas fa-film"></i> Quản lý phim</a>
            <a href="#" class="nav-link"><i class="fas fa-list"></i> Danh mục</a>
            <a href="#" class="nav-link"><i class="fas fa-users"></i> Người dùng</a>
            <a href="/" class="nav-link mt-4" style="color: #fca311;"><i class="fas fa-home"></i> Về cửa hàng</a>
            <a href="/Account/Login" class="nav-link"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a>
        </div>
    </div>

    <div class="main-content">
        <div class="header">
            <h4>Dashboard</h4>
            <div class="d-flex align-items-center">
                <div class="dropdown">
                    <button class="btn btn-dark dropdown-toggle" type="button" data-bs-toggle="dropdown" style="background:#25262b; border: 1px solid #373a40;">
                        <i class="fas fa-user-circle me-2"></i> Admin
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark">
                        <li><a class="dropdown-item" href="#">Cài đặt</a></li>
                        <li><a class="dropdown-item" href="/Account/Login">Đăng xuất</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-info">
                        <p>Tổng số Phim</p>
                        <h3>@ViewBag.TotalMovies</h3>
                    </div>
                    <div class="stat-icon"><i class="fas fa-film"></i></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-info">
                        <p>Danh mục</p>
                        <h3>@ViewBag.TotalCategories</h3>
                    </div>
                    <div class="stat-icon"><i class="fas fa-list"></i></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-info">
                        <p>Người dùng</p>
                        <h3>@ViewBag.TotalUsers</h3>
                    </div>
                    <div class="stat-icon"><i class="fas fa-users"></i></div>
                </div>
            </div>
        </div>

        <div class="card bg-dark border-secondary">
            <div class="card-header border-secondary d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Hoạt động gần đây</h5>
                <button class="btn btn-sm btn-outline-light">Xem thêm</button>
            </div>
            <div class="card-body">
                <p class="text-secondary text-center py-4">Chưa có hoạt động nào được ghi nhận.</p>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
