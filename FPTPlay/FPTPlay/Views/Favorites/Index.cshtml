@model List<FPTPlay.Models.Movie>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FPT Play - Thư viện</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <style>
        :root {
            --primary-red: #e50914;
            --bg-dark: #000;
            --text-light: #e5e5e5;
        }

        body {
            background: #0c0c0c;
            color: var(--text-light);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            margin: 0;
            overflow-x: hidden;
        }

        .navbar {
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        .user-dropdown {
            position: relative;
            display: inline-block;
        }

        .user-dropdown-content {
            display: none;
            position: absolute;
            right: 0;
            top: 100%;
            background: #111;
            min-width: 160px;
            box-shadow: 0 8px 16px rgba(0,0,0,0.5);
            border-radius: 8px;
            z-index: 1055;
            overflow: hidden;
            margin-top: 8px;
        }

            .user-dropdown-content a {
                color: white;
                padding: 12px 16px;
                text-decoration: none;
                display: flex;
                align-items: center;
                transition: background 0.2s;
            }

                .user-dropdown-content a:hover {
                    background: #222;
                }

                .user-dropdown-content a i {
                    margin-right: 10px;
                }
        
        /* Styles for Favorites */
        .empty-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 60vh;
            text-align: center;
            margin-top: 80px;
        }
        
        .btn-return {
            background-color: #ff3c00;
            color: white;
            border-radius: 20px;
            padding: 5px 25px;
            font-weight: 500;
            font-size: 0.9rem;
            text-decoration: none;
            margin-top: 15px;
            transition: background-color 0.2s;
        }
        
        .btn-return:hover {
            background-color: #cc3000;
            color: white;
        }

        .library-title {
            font-size: 1.4rem;
            font-weight: 600;
            margin-left: 20px;
            margin-top: 20px;
            margin-bottom: 40px;
        }

        .movie-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 16px;
            padding: 0 20px;
        }

        .movie-card {
            position: relative;
            border-radius: 8px;
            overflow: hidden;
            background: #111;
            aspect-ratio: 2 / 3;
            transition: transform 0.25s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.25s ease;
            text-decoration: none;
            color: white;
            display: block;
        }

        .movie-card:hover {
            transform: scale(1.08) translateZ(0);
            box-shadow: 0 20px 40px rgba(0,0,0,0.6);
            z-index: 5;
            color: white;
        }

        .movie-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .title-overlay {
            position: absolute;
            inset: 0 0 0 0;
            background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, transparent 60%);
            display: flex;
            align-items: flex-end;
            padding: 12px 10px;
            font-size: 0.9rem;
            font-weight: 500;
            opacity: 0.95;
        }

        .empty-icon-wrapper {
            position: relative; 
            width: 80px; 
            height: 80px; 
            margin-bottom: 2rem;
            opacity: 0.4;
        }
        
        .empty-icon-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }
    </style>
</head>
<body>

    <!-- Header FPT Play -->
    <nav class="navbar navbar-dark navbar-expand-lg fixed-top">
        <div class="container-fluid px-3 px-md-4">
            <a class="navbar-brand" href="/">
                <strong style="color: #e50914; font-size: 1.6rem;">FPT Play</strong>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/" style="color: rgba(255,255,255,0.7);">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="#" style="color: rgba(255,255,255,0.7);">Truyền hình</a></li>
                    <li class="nav-item"><a class="nav-link" href="#" style="color: rgba(255,255,255,0.7);">Phim bộ</a></li>
                    <li class="nav-item"><a class="nav-link" href="#" style="color: rgba(255,255,255,0.7);">Thiếu nhi</a></li>
                    <li class="nav-item"><a class="nav-link" href="#" style="color: rgba(255,255,255,0.7);">Ngoại hạng Anh</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" style="color: rgba(255,255,255,0.7);">Xem thêm</a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-3">
                    <input id="searchInput" class="form-control bg-dark text-white border-0" type="search" placeholder="Tìm kiếm..." style="max-width: 180px;" />
                    <i class="fas fa-bell fa-lg text-white" style="cursor: pointer;"></i>

                    <!-- Icon người dùng + dropdown -->
                    <div class="user-dropdown">
                        <i id="userIcon" class="fas fa-user-circle fa-2x text-white" style="cursor: pointer;"></i>
                        <div id="userDropdownContent" class="user-dropdown-content">
                            <a href="/Account/Login"><i class="fas fa-sign-in-alt"></i> Đăng nhập</a>
                            <a href="/Favorites"><i class="fas fa-heart"></i> Yêu thích</a>
                        </div>
                    </div>

                    <a href="#" class="btn btn-danger btn-sm px-3">Mua gói</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="row w-100 m-0" style="padding-top: 100px;">
        <div class="col-12 px-md-5">
            <h2 class="library-title">Thư viện</h2>

            @if (Model == null || !Model.Any())
            {
                <div class="empty-state">
                    <!-- SVG Icon mô phỏng "Không có dữ liệu" -->
                    <div class="empty-icon-wrapper">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="9" y1="15" x2="15" y2="15"></line>
                        </svg>
                        <!-- Kính lúp -->
                        <svg style="position: absolute; bottom: -10px; right: -15px; width: 40px; height: 40px; background: #0c0c0c; border-radius: 50%; padding: 4px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                            <!-- Dấu X trong kính lúp -->
                            <line x1="8" y1="8" x2="14" y2="14" stroke="#ff3c00"></line>
                            <line x1="14" y1="8" x2="8" y2="14" stroke="#ff3c00"></line>
                        </svg>
                        <!-- Các icon nhỏ xung quanh -->
                        <i class="fas fa-times" style="position: absolute; top: -10px; right: -20px; font-size: 10px; color: #ff3c00; opacity: 0.8;"></i>
                        <i class="fas fa-times" style="position: absolute; bottom: 10px; left: -20px; font-size: 8px; color: #ff3c00; opacity: 0.8;"></i>
                    </div>

                    <h6 class="fw-bold mb-3 mt-3" style="font-size: 1rem;">Không có dữ liệu!</h6>
                    <a href="/" class="btn-return">Về trang chủ</a>
                </div>
            }
            else
            {
                <div class="movie-grid">
                    @foreach (var movie in Model)
                    {
                        <div class="movie-item-wrapper" id="favorite-item-@movie.Id" style="display: flex; flex-direction: column; gap: 8px;">
                            <a href="/Movies/Details/@movie.Id" class="movie-card">
                                <img loading="lazy" src="@movie.PosterUrl" alt="@movie.Title" onerror="this.src='/images/default-poster.jpg'" />
                                <div class="title-overlay">@movie.Title</div>
                            </a>
                            <button class="btn btn-outline-danger btn-sm remove-favorite-btn" data-movie-id="@movie.Id" style="border-radius: 8px;">
                                <i class="fas fa-trash-alt"></i> Bỏ yêu thích
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Toggle dropdown khi click icon user
        const userIcon = document.getElementById('userIcon');
        const dropdownContent = document.getElementById('userDropdownContent');

        if (userIcon && dropdownContent) {
            userIcon.addEventListener('click', function(e) {
                e.stopPropagation(); // Ngăn click lan ra ngoài
                const isVisible = dropdownContent.style.display === 'block';
                dropdownContent.style.display = isVisible ? 'none' : 'block';
            });

            // Ẩn dropdown khi click ra ngoài
            document.addEventListener('click', function(e) {
                if (!userIcon.contains(e.target) && !dropdownContent.contains(e.target)) {
                    dropdownContent.style.display = 'none';
                }
            });
        }

        // Gắn sự kiện cho các nút bỏ yêu thích
        const removeButtons = document.querySelectorAll('.remove-favorite-btn');
        removeButtons.forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                const movieId = this.getAttribute('data-movie-id');
                if (confirm('Bạn có chắc muốn bỏ yêu thích phim này?')) {
                    fetch('/Favorites/Remove/' + movieId, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            const item = document.getElementById('favorite-item-' + movieId);
                            if (item) item.remove();
                            
                            // Nếu không còn phim nào, reload để hiện trạng thái trống
                            const grid = document.querySelector('.movie-grid');
                            if (grid && grid.children.length === 0) {
                                location.reload();
                            }
                        } else {
                            alert(data.message || 'Có lỗi xảy ra!');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Có lỗi xảy ra!');
                    });
                }
            });
        });
    </script>
</body>
</html>
