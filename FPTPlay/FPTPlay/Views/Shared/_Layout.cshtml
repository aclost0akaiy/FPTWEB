<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FPTPlay</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FPTPlay.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">FPTPlay</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        <!-- Nút chuông thông báo -->
                        <li class="nav-item dropdown">
                            <a class="nav-link" href="#" id="notificationDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside">
                                <i class="fa fa-bell" style="font-size: 1.25rem; color: #ffa000; position: relative;">
                                    <span class="badge bg-danger rounded-circle" id="notificationCount" style="display:none;font-size:0.55rem;position:absolute;top:-6px;right:-8px;width:16px;height:16px;padding:2px;border:1px solid #fff;">0</span>
                                </i>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end shadow p-0" aria-labelledby="notificationDropdown" style="width: 450px; background-color: #212121; border: 1px solid #333; border-radius: 8px;">
                                <!-- Header -->
                                <div class="p-3 border-bottom d-flex justify-content-between align-items-center" style="border-color: #333 !important;">
                                    <h6 class="mb-0 text-white fw-bold" style="font-size: 1.1rem;">THÔNG BÁO</h6>
                                    <button type="button" class="btn-close btn-close-white" style="font-size: 0.7rem;" onclick="$('#notificationDropdown').dropdown('toggle')"></button>
                                </div>
                                <!-- Filter Status -->
                                <div class="p-3 border-bottom" style="border-color: #333 !important;">
                                    <div class="d-flex justify-content-end">
                                        <div style="width: 180px;">
                                            <label class="text-secondary mb-1" style="font-size: 0.85rem;">Trạng thái</label>
                                            <select class="form-select form-select-sm text-white" id="filterStatus" style="background-color: #333; border: 1px solid #444; border-radius: 6px;">
                                                <option value="all">Tất cả</option>
                                                <option value="unread">Chưa đọc</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <!-- List -->
                                <div id="notificationList" style="max-height: 420px; overflow-y: auto; overflow-x: hidden;">
                                    <div class="text-center text-muted p-3">Đang tải...</div>
                                </div>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - FPTPlay - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {
            var currentStatus = 'all';

            function loadNotifications() {
                $.get('/Notifications/GetMyNotifications', function (res) {
                    var list = $('#notificationList');
                    list.empty();
                    
                    if (res && res.success) {
                        var count = res.unreadCount;
                        if (count > 0) {
                            $('#notificationCount').text(count).show();
                        } else {
                            $('#notificationCount').hide();
                        }

                        var filteredNotis = res.notifications;
                        if(currentStatus === 'unread') {
                             filteredNotis = filteredNotis.filter(n => !n.isRead);
                        }

                        if (filteredNotis.length === 0) {
                            list.append('<div class="p-3 text-muted text-center" style="font-size:0.9rem;">Không có thông báo nào</div>');
                        } else {
                            filteredNotis.forEach(function (n) {
                                var bgClass = n.isRead ? '' : 'bg-dark opacity-100';
                                var readDot = n.isRead ? '' : `<span class="position-absolute rounded-circle" style="width: 12px; height: 12px; background-color: #ff3b30; border: 2px solid #212121; top: -2px; right: -2px;"></span>`;
                                
                                var item = `
                                <a class="dropdown-item d-flex align-items-center py-3 notification-item ${bgClass}" href="${n.link}" data-id="${n.id}" style="border-bottom: 1px solid #333; white-space: normal; background-color: inherit;">
                                    <div class="position-relative me-3" style="width: 45px; height: 45px; min-width: 45px;">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="background-color: #5e35b1; width: 100%; height: 100%;">
                                            <i class="fa fa-play text-white" style="font-size: 1.1rem; margin-left: 3px;"></i>
                                        </div>
                                        ${readDot}
                                    </div>
                                    <div class="flex-grow-1" style="min-width: 0;">
                                        <div class="text-white fw-bold text-truncate" style="font-size: 0.95rem; margin-bottom: 4px;">
                                            ${n.title}
                                        </div>
                                        <div style="font-size: 0.85rem; color: #ccc; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                            🔔 ${n.message} <span style="color: #ff9800; text-decoration: none;">Xem thêm &gt;</span>
                                        </div>
                                        <div class="mt-2" style="font-size: 0.75rem; color: #888;">
                                            ${n.timeAgo}
                                        </div>
                                    </div>
                                    <div class="ms-3" style="min-width: 120px;">
                                        <img src="${n.posterUrl}" style="width: 120px; height: 75px; object-fit: cover; border-radius: 6px;" class="shadow-sm" alt="Poster" />
                                    </div>
                                </a>`;
                                list.append(item);
                            });
                        }
                    } else {
                        list.append('<div class="p-3 text-muted text-center" style="font-size:0.9rem;">Không thể tải thông báo</div>');
                    }
                }).fail(function() {
                    $('#notificationList').html('<div class="p-3 text-muted text-center" style="font-size:0.9rem;">Lỗi tải thông báo</div>');
                });
            }

            $('#filterStatus').on('change', function() {
                currentStatus = $(this).val();
                loadNotifications();
            });

            $('#notificationDropdown').on('click', function() {
                loadNotifications();
            });

            loadNotifications();

            $(document).on('click', '.notification-item', function (e) {
                e.preventDefault();
                var id = $(this).data('id');
                var link = $(this).attr('href');
                $.post('/Notifications/MarkAsRead', { id: id }, function () {
                    window.location.href = link;
                });
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
